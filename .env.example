# Hedge Fund Analyst — API keys & secrets
#
# Copy to `.env` and fill in. `hfa install` / `hfa env` will prompt for any
# missing key when run interactively and write it here (the file is git-ignored).
# Skills read these from the process environment at run time.

# FinMind — Taiwan market data (finmind)
# Free token: register at https://finmindtrade.com/
FINMIND_TOKEN=

# Financial Modeling Prep — global fundamentals (company-wiki)
# Key: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# Note: 13f-analysis pulls SEC EDGAR with no API key. It only asks for an
# optional SEC_EDGAR_UA contact string (SEC fair-access courtesy); a default
# is built in, so no value is required here.
