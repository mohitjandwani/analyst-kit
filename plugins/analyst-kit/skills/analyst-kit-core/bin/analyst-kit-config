#!/usr/bin/env bash
# analyst-kit-config — get/set/list over the ~/.analyst-kit/config key=value store.
# Never used for secrets (API keys live in ~/.analyst-kit/.env, chmod 600).
set -uo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"
[ -r "$DIR/_analyst-kit-home.sh" ] && . "$DIR/_analyst-kit-home.sh"
AK_HOME="${AK_HOME:-$HOME/.analyst-kit}"
CFG="$AK_HOME/config"

default() {
  case "$1" in
    telemetry) echo "community" ;; # community | anonymous | off — ON by default, explicit opt-out
    update_check) echo "true" ;;
    *) echo "" ;;
  esac
}

case "${1:-}" in
  get)
    [ -n "${2:-}" ] || { echo "usage: analyst-kit-config get <key>" >&2; exit 1; }
    v=$(grep -E "^${2}=" "$CFG" 2>/dev/null | tail -1 | cut -d= -f2-)
    if [ -n "$v" ]; then echo "$v"; else default "$2"; fi
    ;;
  set)
    [ -n "${2:-}" ] && [ -n "${3:-}" ] || { echo "usage: analyst-kit-config set <key> <value>" >&2; exit 1; }
    mkdir -p "$AK_HOME" 2>/dev/null || true
    grep -vE "^${2}=" "$CFG" 2>/dev/null > "$CFG.tmp" || true
    echo "${2}=${3}" >> "$CFG.tmp"
    mv "$CFG.tmp" "$CFG"
    ;;
  list)
    cat "$CFG" 2>/dev/null || true
    ;;
  *)
    echo "usage: analyst-kit-config get <key> | set <key> <value> | list" >&2
    exit 1
    ;;
esac
