#!/usr/bin/env bash
# hfa-preamble — run at the start of every HFA skill. Echoes state lines the
# agent reads (DEDUP, TELEMETRY, ONBOARDED, MISSING_KEYS, UPGRADE, LEARNINGS)
# and logs the start event. Contract: never fails, target <100ms (the only
# network call is hfa-update-check, which is cached to once per day).
set -uo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"
CORE="$(dirname "$DIR")"
HFA_HOME="${HFA_HOME:-$HOME/.hfa}"
export HFA_HOME

SKILL=unknown; ENVKEYS=""
while [ $# -gt 0 ]; do
  case "$1" in
    --skill) SKILL="${2:-unknown}"; shift 2 ;;
    --env)   ENVKEYS="${2:-}"; shift 2 ;;
    *) shift ;;
  esac
done

mkdir -p "$HFA_HOME/analytics" "$HFA_HOME/sessions" 2>/dev/null || true

# Session dedupe: one round of prompts per agent session (~4h window).
# Composed skills (workflow -> capabilities) re-run the preamble; DEDUP: yes
# tells the agent to skip all one-time prompts on those repeats.
SESSION="${PPID:-$$}"
SESS_FILE="$HFA_HOME/sessions/$SESSION"
if [ -n "$(find "$SESS_FILE" -mmin -240 2>/dev/null)" ]; then
  echo "DEDUP: yes"
else
  echo "DEDUP: no"
fi
touch "$SESS_FILE" 2>/dev/null || true
find "$HFA_HOME/sessions" -type f -mmin +240 -delete 2>/dev/null || true

VER="$(tr -d '[:space:]' < "$CORE/VERSION" 2>/dev/null)"
echo "HFA_VERSION: ${VER:-unknown}"

TIER="$("$DIR/hfa-config" get telemetry 2>/dev/null || echo off)"
case "$TIER" in off|anonymous|community) ;; *) TIER=off ;; esac
echo "TELEMETRY: $TIER"
[ -f "$HFA_HOME/.telemetry-prompted" ] && echo "TEL_PROMPTED: yes" || echo "TEL_PROMPTED: no"
[ -f "$HFA_HOME/.onboarded" ] && echo "ONBOARDED: yes" || echo "ONBOARDED: no"

# Missing API keys: process env, then ~/.hfa/.env, then ./.env.
MISSING=""
for K in $(printf '%s' "$ENVKEYS" | tr ',' ' '); do
  [ -n "$K" ] || continue
  if [ -n "$(printenv "$K" 2>/dev/null)" ] \
    || grep -qE "^${K}=." "$HFA_HOME/.env" 2>/dev/null \
    || grep -qE "^${K}=." ./.env 2>/dev/null; then
    continue
  fi
  MISSING="${MISSING:+$MISSING,}$K"
  [ -f "$HFA_HOME/.env-prompted-$K" ] && echo "KEY_PROMPTED_$K: yes" || echo "KEY_PROMPTED_$K: no"
done
echo "MISSING_KEYS: ${MISSING:-none}"

UPD="$("$DIR/hfa-update-check" 2>/dev/null || true)"
echo "UPGRADE: ${UPD:-none}"

LEARN_FILE="$HFA_HOME/learnings.jsonl"
if [ -f "$LEARN_FILE" ]; then
  COUNT=$(wc -l < "$LEARN_FILE" 2>/dev/null | tr -d ' ')
  echo "LEARNINGS: ${COUNT:-0}"
  "$DIR/hfa-learn" recent --skill "$SKILL" --limit 3 2>/dev/null || true
else
  echo "LEARNINGS: 0"
fi

"$DIR/hfa-log" start --skill "$SKILL" --session "$SESSION" 2>/dev/null || true

exit 0
