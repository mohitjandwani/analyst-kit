# Optional convenience for the e2e harness. The primary way to pass keys is INLINE on the
# command, e.g.  ANTHROPIC_API_KEY=sk-… FMP_API_KEY=… bun test/e2e/run.ts
#
# If you'd rather not retype them, copy this file to test/e2e/.env (gitignored) and fill it
# in — the launcher sources it, but anything set inline always takes precedence.

# Required — the agent under test.
ANTHROPIC_API_KEY=

# Optional — only needed by tasks that hit these live APIs.
FMP_API_KEY=
FINMIND_TOKEN=
SEC_EDGAR_USER_AGENT=
