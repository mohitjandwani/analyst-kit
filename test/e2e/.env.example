# The e2e harness's key source. Copy this file to test/e2e/.env (gitignored) and fill it in.
# The launcher loads test/e2e/.env in host mode and it is AUTHORITATIVE — it OVERRIDES any
# matching env vars already in your shell, so a key leaked into the parent environment (e.g.
# an ANTHROPIC_API_KEY meant for your host's own Claude Code) can't shadow these and get
# forwarded into the container. To change a key for a run, edit the .env file.

# Required — the agent under test.
ANTHROPIC_API_KEY=

# Optional — only needed by tasks that hit these live APIs.
FMP_API_KEY=
SERPAPI_API_KEY=
FINMIND_TOKEN=
# SEC contact string (header only — not validated). edgar.py reads SEC_EDGAR_UA; the
# MCP path reads SEC_EDGAR_USER_AGENT. Format: "Name email@example.com". Both optional —
# edgar.py ships a working default — but set them to identify your traffic to the SEC.
SEC_EDGAR_UA=
SEC_EDGAR_USER_AGENT=
