# Secrets — never commit
.env
.env.*
!.env.example

# Dependencies / build artifacts (skills bootstrap these on first use)
node_modules/
**/node_modules/
.venv/
**/__pycache__/
*.pyc
dist/
build/

# OS / editor
.DS_Store

# e2e harness run artifacts (test/e2e/.env is already covered by the .env rules above)
test/e2e/logs/
test/e2e/pdfs/
.gstack/

# manual-test UI run artifacts (prices, charts, PDFs per run)
tools/ta-tester/runs/
